  "projectType": "cli-tool",
  "projectName": "WhatsApp Assistant Bot",
  "projectDescription": "A personal WhatsApp bot for managing reminders, tasks, notes, and utilities through chat commands.",
  "theme": "palm",
  "primaryColor": "#25D366",
  "lightColor": "#34E877",
  "darkColor": "#1DA851",
