  "keyFeatures": [
    "Personal reminders with flexible time formats",
    "Persistent todo list management",
    "Notes storage with search capabilities",
    "Sticker creation from media files",
    "Countdown timers",
    "Spotify playback control",
    "PostgreSQL database persistence",
    "DM-only privacy protection"
  ],
  "publicApiSurface": [
    "!notify <task> <time>",
    "!todo add/list/done/delete/clear",
    "!note save/list/view/delete/search",
    "!sticker [f/full]",
    "!timer start/list/cancel",
    "!spotify or /play, /pause, /skip",
    "!help [command]"
  ]
}
